// Prisma Schema for FoodSafe - Food Rescue Network
// PostgreSQL Database
// Version: Extended with NGO Dashboard support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Model - Base authentication model
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  role          UserRole  @default(DONOR)
  verified      Boolean   @default(false)
  suspended     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  donorProfile   DonorProfile?
  ngoProfile     NgoProfile?

  @@index([email])
  @@index([role])
}

enum UserRole {
  DONOR
  NGO
  ADMIN
}

// Donor Profile - Extended user info for event hosts
model DonorProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  organizationName String?
  phone            String?
  address          String?
  latitude         Float?
  longitude        Float?
  verified         Boolean  @default(false)
  verifiedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodRequests    FoodRequest[]

  @@index([userId])
}

// NGO Profile - Extended user info for verified NGOs
model NgoProfile {
  id                  String             @id @default(cuid())
  userId              String             @unique
  ngoName             String
  registrationNumber  String?
  phone               String?
  address             String?
  latitude            Float?
  longitude           Float?
  serviceRadiusKm     Float              @default(25)
  approvalStatus      ApprovalStatus     @default(PENDING)
  verifiedAt          DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  // Relations
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reservations        Reservation[]

  @@index([userId])
  @@index([approvalStatus])
  @@index([latitude, longitude])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

// Food Request - Core business model for food donations
model FoodRequest {
  id            String           @id @default(cuid())
  donorId       String
  category      FoodCategory
  quantity      Int              // Approximate people served
  description   String?
  isVeg         Boolean
  storageType   StorageType
  latitude      Float
  longitude     Float
  address       String?
  expiryTime    DateTime
  status        FoodRequestStatus @default(OPEN)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  donor         DonorProfile     @relation(fields: [donorId], references: [id], onDelete: Cascade)
  reservation   Reservation?

  // Constraints
  // One active reservation per food request is enforced by Reservation.foodRequestId unique

  @@index([donorId])
  @@index([status])
  @@index([expiryTime])
  @@index([latitude, longitude])
  @@index([status, expiryTime])
}

enum FoodCategory {
  COOKED_VEG
  COOKED_NON_VEG
  DRY_ITEMS
  PACKAGED
  BAKED_GOODS
  FRUITS_VEGETABLES
  DAIRY
  BEVERAGES
  OTHER
}

enum StorageType {
  ROOM_TEMPERATURE
  REFRIGERATED
  FROZEN
}

enum FoodRequestStatus {
  OPEN
  RESERVED
  COMPLETED
  EXPIRED
  CANCELLED
}

// Reservation - Tracks NGO acceptance and pickup
model Reservation {
  id              String            @id @default(cuid())
  foodRequestId   String            @unique
  ngoId           String
  otp             String?           // Plain OTP for display
  otpHash         String
  otpExpiry       DateTime?         // OTP validity period
  photoUrl        String?
  acceptedAt      DateTime          @default(now())
  completedAt     DateTime?
  cancelledAt    DateTime?
  failedAttempts  Int               @default(0)
  status          ReservationStatus @default(PENDING)

  // Relations
  foodRequest     FoodRequest       @relation(fields: [foodRequestId], references: [id], onDelete: Cascade)
  ngo             NgoProfile        @relation(fields: [ngoId], references: [id], onDelete: Cascade)

  // Constraints
  // One active reservation per food request enforced by @unique on foodRequestId

  @@index([foodRequestId])
  @@index([ngoId])
  @@index([status])
  @@index([ngoId, status])
}

enum ReservationStatus {
  PENDING
  COMPLETED
  CANCELLED
}
